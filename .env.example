# Environment Configuration
NODE_ENV="production"
PORT=3000

# APP_URL: The public production URL of your CleanCheck instance (e.g. https://cleancheck.yourdomain.com)
APP_URL="https://cleancheck.yourdomain.com"

# MongoDB Atlas Connection String (System of Record)
# Required in Production. Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://admin:password@cluster0.mongodb.net/cleancheck?retryWrites=true&w=majority"

# Persistent Object Storage Configuration (Cloudflare R2 / AWS S3)
# Required on Render/PaaS platforms to persist uploaded inspection photos, signatures, and daily backup snapshots
S3_BUCKET="cleancheck-storage"
S3_REGION="auto"
S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID="<your-r2-access-key-id>"
S3_SECRET_ACCESS_KEY="<your-r2-secret-access-key>"
S3_PUBLIC_URL="https://pub-cleancheck.<account_id>.r2.dev"

# Local Storage Paths (Used as fallback or when S3 is not configured)
UPLOAD_PATH="./uploads"
BACKUP_PATH="./backups"
LOG_PATH="./logs"

# CORS Allowed Origins (Comma-separated list of allowed domains)
CORS_ORIGINS="https://cleancheck.yourdomain.com,https://cleancheck.onrender.com"

# Google Sheets Reporting Integration (Optional)
GOOGLE_CLIENT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
GOOGLE_SHEETS_ID=""

# SMTP Email Notification Relay (Optional)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Render Deploy Hook URL (For GitHub Actions deployment trigger)
RENDER_DEPLOY_HOOK_URL=""


